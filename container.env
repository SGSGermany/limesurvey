REGISTRY="${REGISTRY:-ghcr.io}"
OWNER="${OWNER:-sgsgermany}"
IMAGE="${IMAGE:-limesurvey}"
TAGS="${TAGS:-latest}"

DOWNLOADS_WEBPAGE_URL="https://community.limesurvey.org/downloads/"
ARCHIVE_URL_TEMPLATE="https://download.limesurvey.org/latest-master/limesurvey%s.zip"
VERSION_PATTERN="6.*.*"

# see https://www.limesurvey.org/manual/LimeSurvey_roadmap#Version_Support_Time_Frames
ENDOFLIFE_AFTER="2026-06-01"
ENDOFLIFE_TRESHOLD="-0 days"

BASE_IMAGE="ghcr.io/sgsgermany/php-fpm:v8.3"
